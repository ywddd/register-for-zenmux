# ============================================================
# ZenMux 注册机配置
# 复制此文件为 .env 并填写你的配置
# ============================================================

# CapSolver 打码平台 API Key（必须，用于自动解决 Turnstile/reCAPTCHA 验证码）
# 获取: https://dashboard.capsolver.com
CAPSOLVER_API_KEY=

# ZenMux 邀请码（可选，多个用逗号分隔）
ZENMUX_INVITE_CODE=

# hotmail_helper 密码（如果设置了密码）
HOTMAIL_HELPER_PASSWORD=

# 浏览器设置
# 是否无头模式（true=无界面，false=显示浏览器窗口用于调试）
HEADLESS=true

# 操作延迟毫秒数（调试时调大方便观察）
SLOW_MO=100

# ============================================================
# 账号配置路径（留空则使用默认值，支持跨平台）
# ============================================================

# Microsoft OAuth 账号配置文件路径
# 默认: 项目目录下的 zenmux_accounts.json
MS_ACCOUNTS_FILE=

# 旧版 Auth0 账号目录
# 默认: 用户主目录下的 .cli-proxy-api
ACCOUNTS_DIR=

# ============================================================
# hotmail_helper（接码服务，随面板自动启动）
# ============================================================

# hotmail_helper API 地址
HOTMAIL_API_BASE=http://127.0.0.1:17373

# hotmail_helper 监听地址/端口（面板启动时透传给子进程）
HOTMAIL_HELPER_HOST=127.0.0.1
HOTMAIL_HELPER_PORT=17373

# ============================================================
# Web 面板
# ============================================================

# 面板监听地址（0.0.0.0 = 对外可访问，127.0.0.1 = 仅本机）
WEB_HOST=127.0.0.1
WEB_PORT=17380

# ============================================================
# 取码超时
# ============================================================

# hotmail_helper 单轮取码最多等多久（默认 60s，与 ZenMux Send 重发冷却对齐）
HOTMAIL_FETCH_TIMEOUT=60000

# ============================================================
# gpt-load 自动导入（可选：pay key 创建成功后自动导入指定分组）
# ============================================================

# gpt-load 地址
GPTLOAD_BASE=http://127.0.0.1:3001

# gpt-load 管理 AUTH_KEY
GPTLOAD_AUTH_KEY=

# pay key 导入到哪个分组 id（留空则不自动导入）
GPTLOAD_PAY_GROUP_ID=
